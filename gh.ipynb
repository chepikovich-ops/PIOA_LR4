from itertools import product
def get_set(filename):
    return set(open(filename, encoding= 'utf-8' ).read().split())
s1 = get_set('set1.txt')
s2 = get_set('set2.txt')
table = list(zip_longest(s1, s2, fillvalue="None"))
print(" Таблица из множеств")
for row in table:
    print(f"ID: {row[0]:<4} | Cat: {row[1]:<6}")
#удаляем дубликаты строк
projection = { (row[0], row[1]) for row in table }
print("Уникальные комбинации (set1 set2):")
for pair in projection:
    print(pair)
